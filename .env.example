# ============================================
# Med 360 Copilot — Environment Variables
# ============================================
# Set at least ONE AI provider API key below.
# The app will auto-detect which provider to use.
# Priority: Anthropic → OpenAI → Google Gemini

# --- AI Provider Keys (set at least one) ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=

# --- Optional: Override AI model ---
# CLAUDE_MODEL=claude-sonnet-4-6
# OPENAI_MODEL=gpt-4o-mini
# GEMINI_MODEL=gemini-2.0-flash

# --- Server ---
PORT=3000
